# Intro Notebook - AMLHC Python Task

import pandas as pd
from sklearn import datasets

# Function to calculate mean values of a dataframe
def calcMeans(dataframe):
    return dataframe.apply(lambda col: col.mean())

# Load iris dataset
iris_X, iris_y = datasets.load_iris(return_X_y=True, as_frame=True)

# Call function
means = calcMeans(iris_X)

print("Calculated means:")
print(means)

# Validate results using describe
print("\nValidation with describe():")
print(iris_X.describe())
